    <model name="hammer">
      <pose>0.8 0.0 0.70 0 0 -1.0</pose> 
      <static>false</static>
      
      <link name="link">
        <inertial>
          <pose>0 0 0 0 0 0</pose>
          <mass>0.815</mass>
