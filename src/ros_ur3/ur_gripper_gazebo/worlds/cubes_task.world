<?xml version="1.0" ?>

<sdf version="1.6">

  <world name="ur3_cubes">
    
    <gui>
      <camera name='user_camera'>
        <pose frame=''>1.28552 1.43709 1.77307 0 0.43 -1.99519</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <gravity>0 0 -9.81</gravity>

    <physics name="default_physics" default="0" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- A gazebo links attacher -->
    <plugin name="ros_link_attacher_plugin" filename="libgazebo_ros_link_attacher.so"/>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.40 0.43 0.67 1</background>
      <shadows>1</shadows>
    </scene>

    <!-- Light Source -->
    <!-- <include>
      <uri>model://sun</uri>
    </include> -->

    <light name="sun" type="directional">
      <cast_shadows>false</cast_shadows>  <!-- 調整是否保留陰影 -->
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.6 0.6 0.6 1</diffuse>    <!-- 調低diffuse讓光線變柔 -->
      <specular>0.3 0.3 0.3 1</specular>  <!-- 可酌量降低高光 -->
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>           <!-- 這幾項也可再調弱光量 -->
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.3 -1</direction>   <!-- 光源方向，可微調陰影位置 -->
    </light>

    <!-- A ground plane -->
    <include>
      <uri>model://floor</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- A gazebo links attacher -->
    <!-- <plugin name="ros_link_attacher_plugin" -->
    <!--         filename="libgazebo_ros_link_attacher.so"/> -->

    <!-- The robot top base -->
    <model name="ur_base_top_left">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.275 -0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_top_right">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.275 0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_top_middle">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.275 0.0 0 0 0 0</pose>
      </include>
    </model>

    <!-- The robot middle base -->
    <model name="ur_base_left">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.775 -0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_right">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.775 0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_middle">
      <include>
        <uri>model://ur_base</uri>
        <pose>0.775 0.0 0 0 0 0</pose>
      </include>
    </model>

    <!-- The robot down base -->
    <model name="ur_base_down_left">
      <include>
        <uri>model://ur_base</uri>
        <pose>1.275 -0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_down_right">
      <include>
        <uri>model://ur_base</uri>
        <pose>1.275 0.5 0 0 0 0</pose>
      </include>
    </model>
    <model name="ur_base_down_middle">
      <include>
        <uri>model://ur_base</uri>
        <pose>1.275 0.0 0 0 0 0</pose>
      </include>
    </model>

